{
  "name": "@botfi/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "eslint . --max-warnings 0",
    "postui:add": "pnpm format:write",
    "test:it": "echo '[packages/ui] No Integration Tests'",
    "test:unit": "echo 'vitest --config=config/unit.config.ts'",
    "typecheck": "tsc --noEmit",
    "ui:add": "shadcn add"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@botfi/eslint-config": "workspace:*",
    "@botfi/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "@turbo/gen": "^2.8.16",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "shadcn": "4.0.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./utils": [
      "./src/utils/index.ts"
    ],
    "./utils/*": [
      "./src/utils/*.ts"
    ],
    "./lib/*": "./src/lib/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  }
}