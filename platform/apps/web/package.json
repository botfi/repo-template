{
  "name": "@botfi/web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:clean": "rm -rf .next .turbo && pnpm build",
    "codegen": "NODE_ENV=development graphql-codegen --config config/codegen.ts && prettier --write \"app/**/*.generated.ts\" --cache",
    "db:generate": "pnpm --workspace-root run db:generate",
    "db:migrate": "pnpm --workspace-root run db:migrate",
    "db:recreate": "pnpm --workspace-root run db:recreate",
    "db:reset": "pnpm --workspace-root run db:reset",
    "db:studio": "pnpm --workspace-root run db:studio",
    "dev": "next dev --turbopack --port ${DEV_WEB_PORT:-15000}",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,md}\"",
    "i18n:parse": "i18next --config config/i18next-parser.ts",
    "lint": "pnpm typecheck && pnpm format:check",
    "prebuild": "pnpm supergraph:compose",
    "predev": "echo 'Use normal graphql instead of supergraph' || pnpm supergraph:compose",
    "start": "next start -p ${DEV_WEB_PORT:-15000}",
    "supergraph:compose": "pnpm rover supergraph compose --log WARN --elv2-license accept --config ../../services/api/supergraph.yaml --format json --output ./app/api/graphql/supergraph/supergraph.json",
    "test:it": "echo 'vitest --config=config/it.config.ts'",
    "test:unit": "echo 'vitest --config=config/unit.config.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "4.1.6",
    "@apollo/client-integration-nextjs": "0.14.4",
    "@botfi/api": "workspace:*",
    "@botfi/env": "workspace:*",
    "@botfi/ui": "workspace:*",
    "accept-language": "3.0.20",
    "diff": "8.0.3",
    "i18next": "25.8.18",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.8",
    "server-only": "0.0.1",
    "translation-check": "1.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@apollo/rover": "0.37.0",
    "@botfi/eslint-config": "workspace:*",
    "@botfi/tsconfig": "workspace:*",
    "@graphql-codegen/cli": "6.1.3",
    "@graphql-codegen/client-preset": "5.2.4",
    "@graphql-codegen/near-operation-file-preset": "5.0.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "i18next-parser": "^9.4.0",
    "typescript": "5.9.3"
  }
}
