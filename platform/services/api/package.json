{
  "name": "@botfi/api",
  "description": "API for the WEB",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsx config/printSchema.ts",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "test:it": "vitest --config=config/it.config.ts",
    "test:unit": "vitest --config=config/unit.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "src/**/*.graphql"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "src/*",
        "src/*/index"
      ]
    }
  },
  "peerDependencies": {
    "zod": "4.0.5"
  },
  "dependencies": {
    "@apollo/gateway": "2.13.1",
    "@apollo/server": "5.4.0",
    "@apollo/subgraph": "2.13.1",
    "@as-integrations/next": "4.1.0",
    "@botfi/db": "workspace:*",
    "@botfi/env": "workspace:*",
    "@graphql-tools/federation": "4.2.13",
    "@pothos/core": "4.12.0",
    "@pothos/plugin-directives": "4.3.0",
    "@pothos/plugin-federation": "4.4.2",
    "@pothos/plugin-prisma": "4.14.2",
    "@pothos/plugin-relay": "4.7.0",
    "@pothos/plugin-scope-auth": "4.1.6",
    "@pothos/plugin-zod": "4.3.0",
    "graphql": "16.13.1",
    "graphql-scalars": "1.25.0",
    "graphql-tag": "2.12.6",
    "graphql-yoga": "5.18.1"
  },
  "devDependencies": {
    "@botfi/tsconfig": "workspace:*",
    "@types/node": "~25.4.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "next": "16.1.6",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  }
}
